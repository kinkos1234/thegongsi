# Production env vars — fly.io secrets로 주입
# 설정: fly secrets set KEY=VALUE [KEY2=VALUE2 ...]

# Database (Supabase / Neon)
DATABASE_URL=postgresql+asyncpg://USER:PASSWORD@HOST:5432/DBNAME?sslmode=require

# Neo4j AuraDB Free
NEO4J_URL=neo4j+s://xxxx.databases.neo4j.io
NEO4J_USER=xxxx                 # AuraDB Free는 인스턴스 ID가 username
NEO4J_PASSWORD=your-auradb-password
NEO4J_DATABASE=xxxx             # AuraDB Free는 인스턴스 ID가 DB 이름

# JWT (프로덕션용 강력한 키 — `openssl rand -hex 32` 로 생성)
JWT_SECRET_KEY=REPLACE_WITH_openssl_rand_hex_32
JWT_ALGORITHM=HS256
JWT_EXPIRE_HOURS=72
AUTO_CREATE_TABLES=false

# Fernet 대칭키 (BYOK 암호화용 — `python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"` 로 생성)
FIELD_ENCRYPTION_KEY=REPLACE_WITH_fernet_generate_key

# LLM / DART
ANTHROPIC_API_KEY=sk-ant-api03-...
DART_API_KEY=your-dart-api-key

# 운영 정책
ADMIN_EMAILS=gentlebros.kjh@gmail.com
ADMIN_JOBS_TOKEN=REPLACE_WITH_RANDOM_SHARED_SECRET
SERVER_KEY_DAILY_LIMIT_MEMO=3
SERVER_KEY_DAILY_LIMIT_ASK=20

# CORS — Vercel 프론트 URL
CORS_ORIGINS=https://thegongsi.vercel.app,https://thegongsi.com
