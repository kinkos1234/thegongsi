DATABASE_URL=postgresql+asyncpg://comad:comad@localhost:5432/comad_stock
# 로컬 SQLite 개발 시:
# DATABASE_URL=sqlite+aiosqlite:///./comad_stock.db

DART_API_KEY=
ANTHROPIC_API_KEY=

NEO4J_URL=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=

JWT_SECRET_KEY=change-this-secret-in-production
JWT_EXPIRE_HOURS=72
AUTO_CREATE_TABLES=true

# Fernet 키 생성: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
FIELD_ENCRYPTION_KEY=
CORS_ORIGINS=http://localhost:3333

TELEGRAM_BOT_TOKEN=
SLACK_WEBHOOK_URL=
DISCORD_WEBHOOK_URL=

# 쿼터 예외 — 운영자 이메일 (쉼표 구분). 이 이메일 사용자는 서버 키 호출 무제한.
# 공개 호스팅 시 자기 이메일 등록 권장.
ADMIN_EMAILS=

# GitHub Actions / 운영자가 /api/admin/jobs/* 를 실행할 때 쓰는 공유 토큰.
ADMIN_JOBS_TOKEN=

# 서버 키 fallback 사용자 일일 한도 (0=무제한)
# SERVER_KEY_DAILY_LIMIT_MEMO=3
# SERVER_KEY_DAILY_LIMIT_ASK=20
